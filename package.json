{
  "name": "@mherod/resect",
  "version": "1.3.0",
  "description": "Surgical TypeScript/JavaScript module refactoring CLI. Move files, rename exports, and watch every import update automatically.",
  "type": "module",
  "bin": {
    "resect": "./bin/resect.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./bun": "./src/runtime/bun.ts",
    "./node": "./src/runtime/node.ts",
    "./runtime": "./src/runtime/index.ts"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/resect",
    "test": "bun test",
    "lint": "pnpm exec biome check --write . && pnpm run lint:eslint",
    "lint:eslint": "eslint src --max-warnings 0",
    "typecheck": "pnpm exec tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm test",
    "git:unlock": "rm -f .git/index.lock",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "[ -d .git ] && husky || true"
  },
  "packageManager": "pnpm@10.30.1",
  "keywords": [
    "typescript",
    "javascript",
    "refactoring",
    "cli",
    "move",
    "rename",
    "imports",
    "exports",
    "module",
    "ast",
    "codemod",
    "tsconfig",
    "monorepo"
  ],
  "author": "Matthew Herod",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mherod/resect.git"
  },
  "homepage": "https://github.com/mherod/resect#readme",
  "bugs": {
    "url": "https://github.com/mherod/resect/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@types/bun": "latest",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript-eslint": "^8.57.0",
    "ultracite": "7.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  }
}
