{
  "name": "@mherod/resect",
  "version": "1.5.0",
  "description": "Surgical TypeScript/JavaScript module refactoring CLI. Move files, rename exports, and watch every import update automatically.",
  "type": "module",
  "bin": {
    "resect": "./bin/resect.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./bun": {
      "bun": "./src/runtime/bun.ts",
      "import": {
        "types": "./dist/runtime/bun.d.ts",
        "default": "./dist/runtime/bun.js"
      }
    },
    "./node": {
      "bun": "./src/runtime/node.ts",
      "import": {
        "types": "./dist/runtime/node.d.ts",
        "default": "./dist/runtime/node.js"
      }
    },
    "./runtime": {
      "bun": "./src/runtime/index.ts",
      "import": {
        "types": "./dist/runtime/index.d.ts",
        "default": "./dist/runtime/index.js"
      }
    }
  },
  "files": [
    "bin",
    "src",
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile bin/resect-bin",
    "build:lib": "tsc -p tsconfig.build.json && bun build src/index.ts src/runtime/bun.ts src/runtime/node.ts src/runtime/index.ts --outdir dist --target bun --format esm --external typescript --splitting",
    "test": "bun test",
    "lint": "pnpm exec biome check --write . && pnpm run lint:eslint",
    "lint:eslint": "eslint src --max-warnings 0",
    "typecheck": "pnpm exec tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm test && pnpm run build:lib",
    "git:unlock": "rm -f .git/index.lock",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "[ -d .git ] && husky || true"
  },
  "packageManager": "pnpm@10.30.1",
  "keywords": [
    "typescript",
    "javascript",
    "refactoring",
    "cli",
    "move",
    "rename",
    "imports",
    "exports",
    "module",
    "ast",
    "codemod",
    "tsconfig",
    "monorepo"
  ],
  "author": "Matthew Herod",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mherod/resect.git"
  },
  "homepage": "https://github.com/mherod/resect#readme",
  "bugs": {
    "url": "https://github.com/mherod/resect/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": ">=5.0.5"
    }
  },
  "dependencies": {
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@types/bun": "latest",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript-eslint": "^8.57.2",
    "ultracite": "7.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  }
}
